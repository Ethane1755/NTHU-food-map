{
  "version": 8,
  "name": "NTHU Dark",
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "sources": {
    "nthu_pmtiles": {
      "type": "vector",
      "url": "pmtiles://PMTILES_URL"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#262a31"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "nthu_pmtiles",
      "source-layer": "water",
      "paint": {
        "fill-color": "#2f4d6c"
      }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "nthu_pmtiles",
      "source-layer": "landcover",
      "paint": {
        "fill-color": "#2f3b3b",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "nthu_pmtiles",
      "source-layer": "landuse",
      "paint": {
        "fill-color": "#303641",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "nthu_pmtiles",
      "source-layer": "building",
      "paint": {
        "fill-color": "#3b4252",
        "fill-outline-color": "#4c566a"
      }
    },
    {
      "id": "roads-minor",
      "type": "line",
      "source": "nthu_pmtiles",
      "source-layer": "transportation",
      "filter": ["in", ["get", "class"], ["literal", ["minor", "service", "track", "path"]]],
      "paint": {
        "line-color": "#4c566a",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12, 0.5,
          18, 2.0
        ]
      }
    },
    {
      "id": "roads-main",
      "type": "line",
      "source": "nthu_pmtiles",
      "source-layer": "transportation",
      "filter": ["in", ["get", "class"], ["literal", ["primary", "secondary", "tertiary", "trunk", "motorway"]]],
      "paint": {
        "line-color": "#81a1c1",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10, 0.8,
          18, 4.0
        ]
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "nthu_pmtiles",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#5e81ac",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8, 0.5,
          16, 2.0
        ]
      }
    },
    {
      "id": "boundaries",
      "type": "line",
      "source": "nthu_pmtiles",
      "source-layer": "boundary",
      "paint": {
        "line-color": "#6b7280",
        "line-dasharray": [2, 2],
        "line-width": 1
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "nthu_pmtiles",
      "source-layer": "place",
      "layout": {
        "text-field": ["coalesce", ["get", "name:zh"], ["get", "name"]],
        "text-font": ["Open Sans Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8, 11,
          16, 15
        ]
      },
      "paint": {
        "text-color": "#e5e9f0",
        "text-halo-color": "#262a31",
        "text-halo-width": 1
      }
    }
  ]
}